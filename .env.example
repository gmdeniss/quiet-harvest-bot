# ── Режим работы ──────────────────────────────────────────────
PAPER_MODE=true          # true = paper trade, false = реальные деньги

# ── Kraken API ─────────────────────────────────────────────────
# Paper mode: оставь пустым — цены берутся из публичного API без авторизации
# Live mode:  нужен ключ с правами Query + Create/Cancel Orders (БЕЗ Withdraw!)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# ── Капитал и риск ─────────────────────────────────────────────
INITIAL_CAPITAL=1000.0       # стартовый капитал в USD
TARGET_CAPITAL=2000.0        # цель для снятия прибыли
POSITION_SIZE=0.15           # 15% капитала на сделку
MAX_SIMULTANEOUS=2           # макс одновременных позиций

# ── Активы портфеля ────────────────────────────────────────────
PORTFOLIO=ETH,BCH,DASH,ZEC

# ── Интервалы (секунды) ────────────────────────────────────────
PRICE_CHECK_INTERVAL=60      # проверка trailing stop каждые 60 сек
SIGNAL_CHECK_HOUR=0          # час UTC для проверки сигналов (0 = полночь)
SIGNAL_CHECK_MINUTE=5        # минута UTC
